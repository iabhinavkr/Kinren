<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Time & End of Day Timer</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e1e2f, #11111b);
            color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            text-align: center;
            background: rgba(255, 255, 255, 0.05);
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            max-width: 450px;
            width: 100%;
        }

        h2 {
            font-size: 1.2rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #a5a5b1;
            margin-bottom: 10px;
        }

        .display {
            font-family: 'Courier New', Courier, monospace;
            font-size: 3rem;
            font-weight: bold;
            color: #4ef0ff;
            text-shadow: 0 0 10px rgba(78, 240, 255, 0.3);
            margin-bottom: 40px;
        }

        .display:last-child {
            margin-bottom: 0;
            color: #ff4e79;
            text-shadow: 0 0 10px rgba(255, 78, 121, 0.3);
        }
    </style>
</head>
<body>

    <div class="container">
        <h2>Current Time</h2>
        <div id="current-time" class="display">00:00:00</div>

        <h2>Time Left Today</h2>
        <div id="countdown" class="display">00:00:00</div>
    </div>

    <script>
        function updateClockAndTimer() {
            const now = new Date();

            // 1. Format and display current time
            const curHours = String(now.getHours()).padStart(2, '0');
            const curMinutes = String(now.getMinutes()).padStart(2, '0');
            const curSeconds = String(now.getSeconds()).padStart(2, '0');
            document.getElementById('current-time').textContent = `${curHours}:${curMinutes}:${curSeconds}`;

            // 2. Set the end of the day target (23:59:59:999)
            const endOfDay = new Date();
            endOfDay.setHours(23, 59, 59, 999);

            // 3. Calculate remaining time
            const timeDiff = endOfDay - now;

            if (timeDiff <= 0) {
                document.getElementById('countdown').textContent = "00:00:00";
                return;
            }

            // Convert remaining milliseconds to hours, minutes, and seconds
            const hoursLeft = Math.floor((timeDiff / (1000 * 60 * 60)) % 24);
            const minutesLeft = Math.floor((timeDiff / (1000 * 60)) % 60);
            const secondsLeft = Math.floor((timeDiff / 1000) % 60);

            // Pad single digits with leading zeros
            const displayHours = String(hoursLeft).padStart(2, '0');
            const displayMinutes = String(minutesLeft).padStart(2, '0');
            const displaySeconds = String(secondsLeft).padStart(2, '0');

            document.getElementById('countdown').textContent = `${displayHours}:${displayMinutes}:${displaySeconds}`;
        }

        // Run immediately on page load, then refresh every 1 second
        updateClockAndTimer();
        setInterval(updateClockAndTimer, 1000);
    </script>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Custom Contact Form</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: #f8fafc;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .form-card {
            background: #1e293b;
            border: 1px solid #334155;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
            max-width: 500px;
            width: 100%;
        }

        .form-header {
            margin-bottom: 24px;
        }

        .form-header h2 {
            font-size: 1.75rem;
            font-weight: 600;
            color: #38bdf8;
            margin-bottom: 8px;
        }

        .form-header p {
            font-size: 0.95rem;
            color: #94a3b8;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-row {
            display: flex;
            gap: 16px;
        }

        .form-row .form-group {
            flex: 1;
        }

        label {
            display: block;
            font-size: 0.85rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #94a3b8;
            margin-bottom: 6px;
        }

        input, textarea, select {
            width: 100%;
            padding: 12px 16px;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 6px;
            color: #f8fafc;
            font-size: 1rem;
            font-family: inherit;
            transition: all 0.2s ease;
        }

        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #38bdf8;
            box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.15);
        }

        textarea {
            resize: vertical;
            min-height: 120px;
        }

        button[type="submit"] {
            width: 100%;
            padding: 14px;
            background: #38bdf8;
            color: #0f172a;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: 0.025em;
            cursor: pointer;
            transition: background 0.2s ease;
        }

        button[type="submit"]:hover {
            background: #7dd3fc;
        }
    </style>
</head>
<body>

    <div class="form-card">
        <div class="form-header">
            <h2>Get in Touch</h2>
            <p>We will respond within 24 hours.</p>
        </div>

        <form action="#" method="POST">
            <div class="form-row">
                <div class="form-group">
                    <label for="first-name">First Name</label>
                    <input type="text" id="first-name" name="first_name" required>
                </div>
                
                <div class="form-group">
                    <label for="last-name">Last Name</label>
                    <input type="text" id="last-name" name="last_name" required>
                </div>
            </div>

            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="you@example.com">
            </div>

            <div class="form-group">
                <label for="subject">Subject</label>
                <select id="subject" name="subject">
                    <option value="general">General Inquiry</option>
                    <option value="support">Technical Support</option>
                    <option value="feedback">Feedback</option>
                </select>
            </div>

            <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" required placeholder="How can we help?"></textarea>
            </div>

            <button type="submit">Submit Form</button>
        </form>
    </div>

</body>
</html>
